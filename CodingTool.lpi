<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <General>
      <Flags>
        <MainUnitHasCreateFormStatements Value="False"/>
        <MainUnitHasTitleStatement Value="False"/>
        <MainUnitHasScaledStatement Value="False"/>
      </Flags>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="CodingTool"/>
      <UseAppBundle Value="True"/>
      <ResourceType Value="res"/>
    </General>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="CodingTool.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="Unit1.pas"/>
        <IsPartOfProject Value="True"/>
        <ComponentName Value="frmMain"/>
        <HasResources Value="True"/>
        <ResourceBaseClass Value="Form"/>
      </Unit>
      <Unit><Filename Value="Unit_Utility.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilityCommon.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilitySQL.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilityVB.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilityCSharp.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilityPascal.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilityPHP.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilityIe.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilityMASM.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilityHtml.pas"/><IsPartOfProject Value="True"/></Unit>
      <Unit><Filename Value="Unit_UtilitySequence.pas"/><IsPartOfProject Value="True"/></Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="CodingTool"/>
    </Target>
    <SearchPaths>
      <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Parsing>
      <SyntaxMode Value="Delphi"/>
    </Parsing>
  </CompilerOptions>
</CONFIG>
